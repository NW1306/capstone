<?xml version="1.0" encoding="UTF-8" ?>
<feedback>
  <!-- Report Metadata -->
  <report_metadata>
    <org_name>Google Inc.</org_name>
    <email>noreply@dmarc.google.com</email>
    <extra_contact_info>https://support.google.com/a/answer/2466580</extra_contact_info>
    <report_id>1234567890.1234567890</report_id>
    <date_range>
      <begin>1709251200</begin>  <!-- 2024-03-01 00:00:00 UTC -->
      <end>1709337599</end>       <!-- 2024-03-01 23:59:59 UTC -->
    </date_range>
  </report_metadata>

  <!-- Policy Published -->
  <policy_published>
    <domain>example.com</domain>
    <adkim>r</adkim>          <!-- Relaxed DKIM alignment -->
    <aspf>r</aspf>            <!-- Relaxed SPF alignment -->
    <p>reject</p>             <!-- Policy for the domain -->
    <sp>reject</sp>           <!-- Policy for subdomains -->
    <pct>100</pct>            <!-- Percentage of emails subject to policy -->
  </policy_published>

  <!-- Record 1: Legitimate Email from Authorized Server -->
  <record>
    <row>
      <source_ip>192.0.2.10</source_ip>  <!-- Google's mail server -->
      <count>150</count>                   <!-- 150 emails from this IP -->
      <policy_evaluated>
        <disposition>none</disposition>    <!-- No action taken (passed) -->
        <dkim>pass</dkim>                  <!-- DKIM passed -->
        <spf>pass</spf>                     <!-- SPF passed -->
      </policy_evaluated>
    </row>
    <identifiers>
      <header_from>example.com</header_from>
      <envelope_from>example.com</envelope_from>
    </identifiers>
    <auth_results>
      <dkim>
        <domain>example.com</domain>
        <result>pass</result>
        <selector>google</selector>
      </dkim>
      <spf>
        <domain>example.com</domain>
        <result>pass</result>
        <scope>mfrom</scope>
      </spf>
    </auth_results>
  </record>

  <!-- Record 2: Suspicious Email - SPF Fail but DKIM Pass -->
  <record>
    <row>
      <source_ip>203.0.113.45</source_ip>  <!-- Unknown server -->
      <count>25</count>                      <!-- 25 emails -->
      <policy_evaluated>
        <disposition>quarantine</disposition> <!-- Sent to spam -->
        <dkim>pass</dkim>                     <!-- DKIM passed -->
        <spf>fail</spf>                        <!-- SPF failed -->
      </policy_evaluated>
    </row>
    <identifiers>
      <header_from>example.com</header_from>
      <envelope_from>mail.example.com</envelope_from>
    </identifiers>
    <auth_results>
      <dkim>
        <domain>example.com</domain>
        <result>pass</result>
        <selector>google</selector>
      </dkim>
      <spf>
        <domain>mail.example.com</domain>
        <result>fail</result>
        <scope>mfrom</scope>
      </spf>
    </auth_results>
  </record>

  <!-- Record 3: Spoofed Email - Both Fail -->
  <record>
    <row>
      <source_ip>198.51.100.78</source_ip>   <!-- Suspicious IP -->
      <count>10</count>                       <!-- 10 emails -->
      <policy_evaluated>
        <disposition>reject</disposition>     <!-- Rejected -->
        <dkim>fail</dkim>                      <!-- DKIM failed -->
        <spf>fail</spf>                         <!-- SPF failed -->
      </policy_evaluated>
    </row>
    <identifiers>
      <header_from>example.com</header_from>
      <envelope_from>fake.com</envelope_from>  <!-- Mismatched envelope -->
    </identifiers>
    <auth_results>
      <dkim>
        <domain>fake.com</domain>
        <result>fail</result>
        <selector>none</selector>
      </dkim>
      <spf>
        <domain>fake.com</domain>
        <result>fail</result>
        <scope>mfrom</scope>
      </spf>
    </auth_results>
  </record>

  <!-- Record 4: Mixed Results - DKIM Fail but SPF Pass -->
  <record>
    <row>
      <source_ip>192.0.2.25</source_ip>
      <count>8</count>
      <policy_evaluated>
        <disposition>none</disposition>
        <dkim>fail</dkim>
        <spf>pass</spf>
      </policy_evaluated>
    </row>
    <identifiers>
      <header_from>example.com</header_from>
      <envelope_from>example.com</envelope_from>
    </identifiers>
    <auth_results>
      <dkim>
        <domain>example.com</domain>
        <result>fail</result>
        <reason>signature missing</reason>
      </dkim>
      <spf>
        <domain>example.com</domain>
        <result>pass</result>
        <scope>mfrom</scope>
      </spf>
    </auth_results>
  </record>

  <!-- Record 5: Forwarded Email - SPF Fail but DKIM Pass (common) -->
  <record>
    <row>
      <source_ip>185.53.180.10</source_ip>    <!-- Forwarding service -->
      <count>42</count>
      <policy_evaluated>
        <disposition>none</disposition>
        <dkim>pass</dkim>
        <spf>fail</spf>                        <!-- SPF often fails when forwarded -->
      </policy_evaluated>
    </row>
    <identifiers>
      <header_from>example.com</header_from>
      <envelope_from>forwarder.com</envelope_from>
    </identifiers>
    <auth_results>
      <dkim>
        <domain>example.com</domain>
        <result>pass</result>
        <selector>google</selector>
      </dkim>
      <spf>
        <domain>forwarder.com</domain>
        <result>fail</result>
        <scope>mfrom</scope>
      </spf>
    </auth_results>
  </record>
</feedback>